    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking (CLIENT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Booking created', () => pm.response.to.have.status(200));",
                  "pm.test('Status is PENDING', () => pm.expect(r.status).to.equal('PENDING'));",
                  "pm.test('Has totalPrice', () => pm.expect(r.totalPrice).to.be.a('number'));",
                  "if (r.id) pm.collectionVariables.set('bookingId', r.id.toString());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api","bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apartmentId\": {{apartmentId}},\n  \"startDate\": \"2026-06-01\",\n  \"endDate\": \"2026-06-05\",\n  \"guestsCount\": 2\n}"
            }
          }
        },
        {
          "name": "Create Booking - Date Conflict (should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Conflict returns 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api","bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"apartmentId\": {{apartmentId}},\n  \"startDate\": \"2026-06-02\",\n  \"endDate\": \"2026-06-04\",\n  \"guestsCount\": 1\n}"
            }
          }
        },
        {
          "name": "Get My Bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get bookings success', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api","bookings"] }
          }
        },
        {
          "name": "Get Booking by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get booking success', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}"] }
          }
        },
        {
          "name": "Confirm Booking (PENDING → CONFIRMED)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Booking confirmed', () => pm.response.to.have.status(200));",
                  "pm.test('Status is CONFIRMED', () => pm.expect(r.status).to.equal('CONFIRMED'));",
                  "pm.test('confirmedAt set', () => pm.expect(r.confirmedAt).to.not.be.null);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/confirm", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","confirm"] }
          }
        },
        {
          "name": "Cancel Booking by CLIENT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Booking cancelled', () => pm.response.to.have.status(200));",
                  "pm.test('Status is CANCELLED_BY_CLIENT', () => pm.expect(r.status).to.equal('CANCELLED_BY_CLIENT'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","cancel"] }
          }
        },
        {
          "name": "Cancel Booking by LANDLORD",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Booking cancelled by landlord', () => pm.response.to.have.status(200));",
                  "pm.test('Status is CANCELLED_BY_LANDLORD', () => pm.expect(r.status).to.equal('CANCELLED_BY_LANDLORD'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel-by-landlord", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","cancel-by-landlord"] }
          }
        }
      ]
    },
