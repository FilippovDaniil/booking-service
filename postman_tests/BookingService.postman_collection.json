            }
          }
        },
        {
          "name": "Delete (Deactivate) Apartment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Apartment deactivated', () => pm.response.to.have.status(204));"
                ]
              }
            }
