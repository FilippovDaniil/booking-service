                "exec": [
                  "pm.test('Should be 403 for non-admin', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] }
          }
        }
      ]
    },
    {
      "name": "Apartments",
      "item": [
        {
          "name": "Create Apartment (LANDLORD)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Apartment created', () => pm.response.to.have.status(200));",
                  "pm.test('Has id', () => pm.expect(r.id).to.be.a('number'));",
                  "if (r.id) pm.collectionVariables.set('apartmentId', r.id.toString());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/apartments", "host": ["{{baseUrl}}"], "path": ["api","apartments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Уютная квартира в центре\",\n  \"description\": \"Светлая квартира с видом на парк, свежий ремонт, всё необходимое для комфортного проживания\",\n  \"city\": \"Москва\",\n  \"street\": \"Тверская\",\n  \"houseNumber\": \"10\",\n  \"pricePerNight\": 3500.00,\n  \"maxGuests\": 3,\n  \"amenities\": [\"Wi-Fi\", \"Парковка\", \"Кухня\", \"Кондиционер\"],\n  \"photos\": [\n    \"https://images.unsplash.com/photo-1522708323590-d24dbb6b0267\",\n    \"https://images.unsplash.com/photo-1493809842364-78817add7ffb\"\n  ]\n}"
            }
          }
        },
        {
          "name": "Create Apartment 2 (LANDLORD)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/apartments", "host": ["{{baseUrl}}"], "path": ["api","apartments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Студия у метро\",\n  \"description\": \"Компактная студия рядом со станцией метро\",\n  \"city\": \"Москва\",\n  \"street\": \"Арбат\",\n  \"houseNumber\": \"25\",\n  \"pricePerNight\": 2000.00,\n  \"maxGuests\": 2,\n  \"amenities\": [\"Wi-Fi\", \"Кухня\"],\n  \"photos\": [\"https://images.unsplash.com/photo-1560448204-e02f11c3d0e2\"]\n}"
            }
          }
        },
        {
          "name": "Search Apartments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Search success', () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test('Returns page object', () => pm.expect(r).to.have.property('content'));",
                  "pm.test('Content is array', () => pm.expect(r.content).to.be.an('array'));",
                  "if (r.content && r.content.length > 0) {",
                  "  pm.collectionVariables.set('apartmentId', r.content[0].id.toString());",
                  "  console.log('Found', r.content.length, 'apartments');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/apartments?city=Москва&startDate=2026-06-01&endDate=2026-06-05&guests=2",
              "host": ["{{baseUrl}}"],
              "path": ["api","apartments"],
              "query": [
                { "key": "city",      "value": "Москва" },
                { "key": "startDate", "value": "2026-06-01" },
                { "key": "endDate",   "value": "2026-06-05" },
                { "key": "guests",    "value": "2" },
                { "key": "minPrice",  "value": "1000", "disabled": true },
                { "key": "maxPrice",  "value": "5000", "disabled": true },
                { "key": "page",      "value": "0", "disabled": true },
                { "key": "size",      "value": "10", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Apartment by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get apartment success', () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test('Has name', () => pm.expect(r.name).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/apartments/{{apartmentId}}", "host": ["{{baseUrl}}"], "path": ["api","apartments","{{apartmentId}}"] }
          }
        },
