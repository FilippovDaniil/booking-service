                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/stats", "host": ["{{baseUrl}}"], "path": ["api","admin","stats"] }
          }
        },
        {
          "name": "Force Change Booking Status (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/bookings/{{bookingId}}/status?status=COMPLETED",
              "host": ["{{baseUrl}}"],
              "path": ["api","admin","bookings","{{bookingId}}","status"],
              "query": [{ "key": "status", "value": "COMPLETED" }]
            }
          }
        },
        {
          "name": "Block User (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/1/block", "host": ["{{baseUrl}}"], "path": ["api","users","1","block"] }
          }
        }
      ]
    },
