{
  "info": {
    "name": "Booking Service API",
    "_postman_id": "booking-service-collection",
    "description": "Full test collection for the Booking Service (Airbnb analogue). Base URL: http://localhost:8555\n\n## Quick Start\n1. Run **Register CLIENT** to create a client account\n2. Run **Register LANDLORD** to create a landlord account\n3. Run **Login CLIENT** — accessToken saves automatically\n4. As LANDLORD: run **Create Apartment**\n5. As CLIENT: run **Search Apartments**, then **Create Booking**\n6. Run **Confirm Booking**\n7. Run **Create Review** after booking is COMPLETED",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8555", "type": "string" },
    { "key": "accessToken",   "value": "", "type": "string" },
    { "key": "refreshToken",  "value": "", "type": "string" },
    { "key": "landlordToken", "value": "", "type": "string" },
    { "key": "adminToken",    "value": "", "type": "string" },
    { "key": "apartmentId",   "value": "1",  "type": "string" },
    { "key": "bookingId",     "value": "1",  "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register CLIENT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', r.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', r.refreshToken);",
                  "  pm.test('Register CLIENT success', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@booking.com\",\n  \"password\": \"client123\",\n  \"firstName\": \"Ivan\",\n  \"lastName\": \"Petrov\",\n  \"role\": \"CLIENT\"\n}"
            }
          }
        },
        {
          "name": "Register LANDLORD",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.accessToken) {",
                  "  pm.collectionVariables.set('landlordToken', r.accessToken);",
                  "  pm.test('Register LANDLORD success', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"landlord@booking.com\",\n  \"password\": \"landlord123\",\n  \"firstName\": \"Petr\",\n  \"lastName\": \"Sidorov\",\n  \"role\": \"LANDLORD\"\n}"
            }
          }
        },
        {
          "name": "Register ADMIN (should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cannot register as ADMIN', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@booking.com\",\n  \"password\": \"admin123\",\n  \"firstName\": \"Admin\",\n  \"lastName\": \"Admin\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login CLIENT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Login success', () => pm.response.to.have.status(200));",
                  "pm.test('Has accessToken', () => pm.expect(r.accessToken).to.not.be.empty);",
                  "pm.test('Has refreshToken', () => pm.expect(r.refreshToken).to.not.be.empty);",
                  "pm.collectionVariables.set('accessToken', r.accessToken);",
                  "pm.collectionVariables.set('refreshToken', r.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@booking.com\",\n  \"password\": \"client123\"\n}"
            }
          }
        },
        {
          "name": "Login LANDLORD",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Landlord login success', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('landlordToken', r.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"landlord@booking.com\",\n  \"password\": \"landlord123\"\n}"
            }
          }
        },
        {
          "name": "Login wrong password (should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Wrong password returns 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@booking.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "pm.test('Token refreshed', () => pm.response.to.have.status(200));",
                  "pm.test('New accessToken issued', () => pm.expect(r.accessToken).to.not.be.empty);",
                  "pm.collectionVariables.set('accessToken', r.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout success', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
