          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/reviews", "host": ["{{baseUrl}}"], "path": ["api","reviews"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": {{bookingId}},\n  \"rating\": 5,\n  \"comment\": \"Отличная квартира! Всё как на фото, хозяин очень отзывчивый. Обязательно вернёмся!\"\n}"
            }
          }
        },
        {
          "name": "Get Reviews for Apartment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get reviews success', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/apartments/{{apartmentId}}/reviews", "host": ["{{baseUrl}}"], "path": ["api","apartments","{{apartmentId}}","reviews"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Stats (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Stats or forbidden', () => {",
