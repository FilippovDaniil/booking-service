# ============================================================
#  .env.example — пример файла переменных окружения
#
#  КАК ИСПОЛЬЗОВАТЬ:
#    1. Скопируй этот файл: cp .env.example .env
#    2. Замени значения на реальные
#    3. Файл .env НЕ коммитится в git (он в .gitignore)
#
#  docker-compose.prod.yml читает переменные из .env автоматически.
# ============================================================

# Пароль базы данных PostgreSQL
DB_PASSWORD=your_strong_password_here

# JWT секрет — минимум 32 символа, лучше 64+
# Генерация: openssl rand -hex 64
JWT_SECRET=veryLongAndSecretKeyThatIsAtLeast256bitsLongReplaceInProduction

# GitLab Container Registry (заполняется автоматически в CI, нужен для ручного деплоя)
CI_REGISTRY_IMAGE=registry.gitlab.com/your-username/your-project
